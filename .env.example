APP_HOST=0.0.0.0
APP_PORT=8010
APP_WORKERS=1

STORAGE_DIR=app/storage
MAX_UPLOAD_MB=128
DEFAULT_LANGUAGE=Chinese
DEFAULT_PARSER_MODE=auto
MAX_PAGE_NUMBER=1000

# Official DeepDoc runtime.
# plain: use text extraction only. deepdoc: force OCR/layout/table. auto: try deepdoc then fallback to plain.
LAYOUT_RECOGNIZER_TYPE=onnx
PARALLEL_DEVICES=0
PDF_PARSER_PAGE_BATCH_SIZE=50
HF_ENDPOINT=https://hf-mirror.com
HF_TOKEN=
